APP_ENV=local
APP_NAME=Perq API
API_V1_PREFIX=/api/v1
DEBUG=true

# Supabase Postgres connection string. Prefer the direct Postgres connection
# string for migrations. Include sslmode=require.
DATABASE_URL=postgresql+psycopg://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres?sslmode=require

# Optional Supabase project metadata for future use.
SUPABASE_URL=https://[YOUR-PROJECT-REF].supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
